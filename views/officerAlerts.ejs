<!DOCTYPE html>
<html>
<head>
  <title>Officer Alerts</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
</head>

<body style="background-color:#f4f6f9;">

<div class="container mt-5">

  <h1 class="mb-3">Compliance Officer Dashboard</h1>

  <p class="mb-4">
    <a href="/api/officer/alerts">Alerts</a> |
    <a href="/api/officer/audit-logs">Audit Logs</a> |
    <a href="/api/officer/report">Reports</a>
  </p>

  <div class="card shadow-sm">
    <div class="card-body">

      <h2 class="mb-4">Alert Review Queue</h2>

      <table class="table table-bordered table-hover align-middle">

        <thead class="table-dark">
          <tr>
            <th>Database ID</th>
            <th>Alert ID</th>
            <th>Transaction ID</th>
            <th>Risk Level</th>
            <th>Status</th>
            <th>Reason</th>
            <th>Action</th>
          </tr>
        </thead>

        <tbody>

          <% alerts.forEach(alert => { %>

            <tr>

              <td><%= alert.id %></td>

              <td>
                <%= alert.alert_id || 'N/A' %>
              </td>

              <td>
                <%= alert.transaction_id %>
              </td>

              <td>

                <% if (alert.risk_level === 'High') { %>

                  <span class="badge bg-danger">
                    <%= alert.risk_level %>
                  </span>

                <% } else if (alert.risk_level === 'Medium') { %>

                  <span class="badge bg-warning text-dark">
                    <%= alert.risk_level %>
                  </span>

                <% } else { %>

                  <span class="badge bg-success">
                    <%= alert.risk_level %>
                  </span>

                <% } %>

              </td>

              <td>
                <%= alert.status %>
              </td>

              <td>
                <%= alert.reason || 'No reason provided' %>
              </td>

              <td>

                <a
                  href="/api/officer/alerts/<%= alert.id %>"
                  class="btn btn-primary btn-sm"
                >
                  View Details
                </a>

              </td>

            </tr>

          <% }) %>

        </tbody>

      </table>

    </div>
  </div>

</div>

</body>
</html>